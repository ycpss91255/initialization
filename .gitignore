tmp

# kcov coverage output from `just -f justfile.ci coverage` (local + CI artefact).
/coverage/

# Test runtime scratch (`just -f justfile.ci clean` removes it). Holds throwaway sync-E2E
# ssh keys (test/integration/sync/receiver-entry.sh) — never commit.
/.tmp/

# Yazi: ignore `ya pkg` auto-installed packages, keep only manually-tracked plugins
module/config/yazi/plugins/*
!module/config/yazi/plugins/dockerfile.yazi
module/config/yazi/flavors/

# Fish: ignore auto-generated completions, keep only manually-tracked ones
module/config/fish/completions/*
!module/config/fish/completions/tmuxp-ssh.fish
!module/config/fish/completions/claude-rm.fish

# Fish runtime state (per-machine)
module/config/fish/fish_history
module/config/fish/fish_variables*

# Claude Code local-only settings (machine-specific permission allow-list).
# Project-wide config (hooks, enabled plugins) lives in tracked .claude/settings.json.
.claude/settings.local.json
.claude/cache/
# Claude Code agent/workflow git worktrees — transient per-task checkouts.
# The WorktreeCreate hook (.agents/hook/worktree_create.sh) puts them at the
# repo-root .worktree/; .claude/worktrees/ is the upstream default kept ignored
# as a fallback. Both are runtime scratch, never vendored, and are pruned from
# the lint/coverage find in script/ci/ci.sh.
.worktree/
.claude/worktrees/

# Claude Code session state: never vendor anything the repo-side .claude/
# projects/ might hold (JSONL transcripts + session sidecars are large +
# privacy data). Memory lives canonically under .agents/memory/ (tracked,
# shareable); Claude's HOME-side ~/.claude/projects/<key>/memory symlink points
# straight at .agents/memory (no repo-side .claude/projects/memory needed).
.claude/projects/

# Other agent CLIs' local state
skills-lock.json

# Skill layout (refs #150): EVERY skill lives canonically under
# .agents/skills/<name>/. `.claude/skills` is a single whole-dir symlink into
# .agents/skills (like .claude/{hook,rules,script}), so the tracked-vs-local
# distinction is made ONCE, at the canonical end: repo-owned skills are tracked
# under .agents/skills/; third-party skills (installed via the `skills` CLI)
# stay machine-local + gitignored there, but still resolve through the same
# .claude/skills symlink. git cannot re-include a path once a parent dir is
# ignored, so .agents is ignored at the contents level (/*) with layer-by-layer
# negations. The .claude/skills symlink itself is tracked (no rule ignores it).
.agents/*
# Fully repo-owned canonical dirs — track everything (incl. newly-added files).
!.agents/hook
!.agents/hook/**
!.agents/rules
!.agents/rules/**
!.agents/script
!.agents/script/**
!.agents/memory
!.agents/memory/**
# skills mix repo-owned (tracked) + third-party (machine-local) — per-item.
!.agents/skills
.agents/skills/*
!.agents/skills/auto-merge-on-green
!.agents/skills/semver-bump
!.agents/skills/wait-pr-ci

# git worktree workspaces — per-branch checkouts for fix/feature work.
# Convention: worktree/<N>-<slug>/ where N is the issue/task number.
# The directory itself is tracked (worktree/.gitkeep) so the convention is
# discoverable on fresh clone; contents are ignored.
worktree/*
!worktree/.gitkeep
