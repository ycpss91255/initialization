tmp

# kcov coverage output from `just -f justfile.ci coverage` (local + CI artefact).
/coverage/

# Test runtime scratch (`just -f justfile.ci clean` removes it). Holds throwaway sync-E2E
# ssh keys (test/integration/sync/receiver-entry.sh) — never commit.
/.tmp/

# Yazi: ignore `ya pkg` auto-installed packages, keep only manually-tracked plugins
module/config/yazi/plugins/*
!module/config/yazi/plugins/dockerfile.yazi
module/config/yazi/flavors/

# Fish: ignore auto-generated completions, keep only manually-tracked ones
module/config/fish/completions/*
!module/config/fish/completions/tmuxp-ssh.fish
!module/config/fish/completions/claude-rm.fish

# Fish runtime state (per-machine)
module/config/fish/fish_history
module/config/fish/fish_variables*

# Claude Code local-only settings (machine-specific permission allow-list).
# Project-wide config (hooks, enabled plugins) lives in tracked .claude/settings.json.
.claude/settings.local.json
.claude/cache/

# Claude Code session state: ignore everything under projects/ EXCEPT memory/.
# JSONL transcripts and session sidecar dirs are large + contain privacy data.
.claude/projects/*
!.claude/projects/memory/
!.claude/projects/memory/**

# Other agent CLIs' local state
skills-lock.json

# Skill layout (refs #150, supersedes the 2026-05-21 migration): EVERY skill
# lives canonically under .agents/skills/<name>/ and is symlinked from
# .claude/skills/<name>. Third-party skills (installed via the `skills` CLI)
# stay machine-local; repo-owned skills are tracked at BOTH ends — the
# canonical dir under .agents/skills/ and the symlink under .claude/skills/.
# git cannot re-include a path once a parent dir is ignored, so .agents is
# ignored at the contents level (/*) with layer-by-layer negations.
.agents/*
!.agents/skills
.agents/skills/*
!.agents/skills/auto-merge-on-green
!.agents/skills/semver-bump
!.agents/skills/wait-pr-ci

.claude/skills/*
!.claude/skills/auto-merge-on-green
!.claude/skills/semver-bump
!.claude/skills/wait-pr-ci

# git worktree workspaces — per-branch checkouts for fix/feature work.
# Convention: worktree/<N>-<slug>/ where N is the issue/task number.
# The directory itself is tracked (worktree/.gitkeep) so the convention is
# discoverable on fresh clone; contents are ignored.
worktree/*
!worktree/.gitkeep
