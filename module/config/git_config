[init]
    defaultBranch = main
[core]
    editor = nvim
    pager = delta
[interactive]
    diffFilter = delta --color-only
[color]
    ui = auto
[format]
    pretty = format:%C(yellow)%h%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset %C(red)%d%Creset
[alias]
    st = status
    sw = "!f() { git switch \"$1\" 2>/dev/null || git switch -c \"$1\"; }; f"
    br = branch
    cm = commit -m
    cam = commit --amend --no-edit
    lg = log --graph --decorate --all
    ; lg = log --graph --decorate --oneline --all
    pl = pull --rebase
    pop = stash pop
[push]
    default = current
[pull]
    rebase = true
[diff]
    algorithm = histogram
[delta]
    navigate = true
    line-numbers = true
    side-by-side = true
    syntax-theme = OneHalfDark
[merge]
    conflictStyle = zdiff3
[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
