#!/usr/bin/env expect
# real_install_flow_gum.exp — AC-11 (issue #178, S2) on the LIVE gum backend.
#
# Same destination as real_install_flow.exp (Run → Review → Proceed → REAL
# install fork), but gum's widgets differ from whiptail (aligned on results,
# not pixels — #171):
#   - main menu / Review are `gum choose`: ↓ moves, Enter selects, Esc cancels
#   - the checklist is `gum choose --no-limit`: Space toggles, Enter confirms
#     (no whiptail-style `[*]` cell, so we assert the toggle by RESULT — the
#     install lands — not by a painted checkmark)
#
# Fixture: gum is the ONLY Optional module, so the main menu rows are
#   quick-setup(0) optional(1) sep(2) manage(3) secrets(4) sysinfo(5) sep(6)
#   run(7); gum choose highlight starts at row 0 each render.
#
# Exit codes: 0 = the forked real install succeeded; 99 = harness assertion;
# else = the real install's own rc surfaced through the TUI.

source [file join [file dirname [file normalize [info script]]] tui_expect_lib.tcl]

tui_spawn --backend gum

# 1. Main menu.
tui_expect_text "Quick Setup"
tui_expect_text "Optional"
tui_expect_text "Run"

# 2. Enter Optional (row 0 → row 1).
tui_key_down
tui_key_enter

# 3. Optional checklist (gum choose --no-limit): gum is the first row.
#    Space toggles it on, Enter confirms the page.
tui_expect_text "Optional Modules"
tui_key_space
tui_key_enter

# 4. Back on the main menu; walk to Run (row 7).
tui_expect_text "Quick Setup"
for {set i 0} {$i < 7} {incr i} { tui_key_down }
tui_key_enter

# 5. Review & Install (gum choose): the proceed row is first (single module,
#    no deps). gum renders the ITEM label, not the tag, so match the label
#    ("Install now …"). Enter confirms → the TUI forks the REAL install.
tui_expect_text "Review & Install"
tui_expect_text "Install now"
tui_key_enter

# 6. Wait for the forked real install to finish; the TUI exits with its rc.
set rc [tui_wait_exit_rc]
if {$rc != 0} { tui_die "TUI exited rc=$rc (want 0); real install fork failed on gum" }
exit 0
