#!/usr/bin/env expect
# smoke_flow.exp <whiptail> — AC-10 layer 2: the literal §11.1 flow on the
# live whiptail widget under a pseudo-tty (#171 dropped dialog; gum drives
# its own smoke_flow_gum.exp):
#   open main menu → enter Optional → check one item → OK → Exit
#
# In-flow assertions (each tui_expect_text is one): every screen renders
# its text, the checkbox toggles to [*], the Cancel button is relabeled
# < Exit >, and the TUI exits 0. The bats wrapper (tui_smoke_spec.bats)
# re-asserts zero file writes and that no action was ever forked.
#
# Exit codes: 0 = flow green; 99 = harness assertion failed (see stderr);
# anything else = the TUI's own nonzero rc.

source [file join [file dirname [file normalize [info script]]] tui_expect_lib.tcl]

if {[llength $argv] != 1} { tui_die "usage: smoke_flow.exp <whiptail>" }
set backend [lindex $argv 0]

# #171: force the backend so the run skips detection AND the gum install
# prompt (under a pty `[[ -t 0 ]]` is true, so an unforced gum-absent run
# would block on "Install gum? [Y/n]").
tui_spawn --backend $backend

# 1. Main menu visible (§8.1 rows + the relabeled < Exit > button).
tui_expect_text "Quick Setup"
tui_expect_text "Optional"
tui_expect_text "Run"
tui_expect_text "Exit"

# 2. Enter Optional: highlight starts on quick-setup; three rows down
#    (base → recommended → optional), then Enter.
tui_key_down
tui_key_down
tui_key_down
tui_key_enter

# 3a. ADR-0024 D10 nested drill-down: optional has 2 TAGS[0] buckets, so a
#     sub-category menu (agent / cli-essentials) precedes the checklist. The
#     highlight starts on the first row (agent); Enter opens that bucket's leaf.
tui_expect_text "Optional Modules"
tui_expect_text "agent"
tui_key_enter

# 3b. Checklist visible; Space checks the highlighted first item
#    (claude-code — the agent bucket's lone module). Match the row's
#    description, not the tag: dialog colors the tag's hotkey letter, so
#    "claude-code" is never a contiguous byte sequence on the stream.
tui_expect_text "Anthropic agent CLI"
tui_key_space
# The toggle repaint differs per backend: dialog cursor-addresses the lone
# checkbox cell and writes just `*`; whiptail redraws the row. Either way
# the first `*` on the whole stream is the checked mark (box borders are
# line-drawing chars, and no fixture text contains an asterisk).
tui_expect_re {\*} "the checked \[*\] mark"
tui_key_enter   ;# < OK > stores the page in the in-memory accumulator

# 4. OK returns to the SUB-CATEGORY menu (the drill-down loop). Back out of it
#    to reach the main menu.
tui_expect_text "Optional Modules"
tui_press_exit $backend

# 5. Back on the main menu (fresh redraw).
tui_expect_text "Quick Setup"

# 6. < Exit > with a pending selection: the #206 guard asks to confirm before
#    dropping it. Confirm "leave" (the yesno default is Yes/Exit) → clean rc 0,
#    selection dropped with the process (Q43).
tui_press_exit $backend
tui_expect_text "Unsent selections"
tui_key_enter
set rc [tui_wait_exit_rc]
if {$rc != 0} { tui_die "TUI exited rc=$rc (want 0) on backend=$backend" }
exit 0
