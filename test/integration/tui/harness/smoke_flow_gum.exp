#!/usr/bin/env expect
# smoke_flow_gum.exp — AC-10 layer 2, gum backend (#171): the literal §11.1
# flow on the LIVE gum binary under a pseudo-tty:
#   open main menu → enter Optional → check one item → OK → Exit
#
# gum differs from dialog/whiptail behaviorally (aligned on results, not
# pixels — #171):
#   - the main menu is `gum choose`: ↓ moves, Enter selects, Esc cancels
#     (no Cancel button — Esc IS < Exit >, gum returns 130 → the TUI main
#     loop maps that to a clean rc 0 / Q43 drop)
#   - the checklist is `gum choose --no-limit`: Space toggles, Enter confirms
#
# The TUI is forced onto gum with `--backend gum` (skips detection + the
# install prompt). Exit codes: 0 = green; 99 = harness assertion; else = the
# TUI's own rc.

source [file join [file dirname [file normalize [info script]]] tui_expect_lib.tcl]

tui_spawn --backend gum

# 1. Main menu visible (gum choose --header carries the §8.1 rows).
tui_expect_text "Quick Setup"
tui_expect_text "Optional"
tui_expect_text "Run"

# 2. Enter Optional. gum choose highlight starts on the first item
#    (quick-setup); three ↓ then Enter (base → recommended → optional).
tui_key_down
tui_key_down
tui_key_down
tui_key_enter

# 3. Checklist (gum choose --no-limit): Space toggles the highlighted first
#    item, Enter confirms the page (stored in the in-memory accumulator).
tui_expect_text "Optional Modules"
tui_key_space
tui_key_enter

# 4. Back on the main menu (gum re-renders the header rows).
tui_expect_text "Quick Setup"

# 5. < Exit > on gum is Esc: cancels gum choose (130) → the TUI main loop
#    drops the selection and exits cleanly (rc 0, Q43).
send -- "\x1b"
set rc [tui_wait_exit_rc]
if {$rc != 0} { tui_die "TUI exited rc=$rc (want 0) on gum" }
exit 0
